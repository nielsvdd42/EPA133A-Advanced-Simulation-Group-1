    "def snap_bridges(row, bridge_data, lrp_data):\n",
    "    LRP = row['LRPName']\n",
    "    road = row['road']\n",
    "    LRP_row = lrp_data[lrp_data['road'] == road]\n",
    "\n",
    "    \n",
    "    LRP_info = lrp_data[lrp_data['LRPName'] == LRP and lrp_data['road'] == road]\n",
    "    return LRP_info['lat'].values[0], LRP_info['lon'].values[0]\n",
    "    \n",
    "check = df_bridges_fixed.apply(lambda row: snap_bridges(row, df_bridges_fixed, df_roads), axis=1)\n",
    "check    "
   ]
