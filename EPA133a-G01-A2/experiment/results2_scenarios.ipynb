    "    }\n",
    "   },\n",
    "   \"source\": [\n",
    "    \"import pandas as pd\\n\",\n",
    "    \"import matplotlib.pyplot as plt\\n\",\n",
    "    \"import seaborn as sns\\n\",\n",
    "    \"import glob\\n\",\n",
    "    \"import os\\n\",\n",
    "    \"import re\\n\",\n",
    "    \"\\n\",\n",
    "    \"sns.set_theme(style=\\\"whitegrid\\\")\\n\",\n",
    "    \"plt.rcParams['figure.figsize'] = [12, 7]\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"path = '.'\\n\",\n",
    "    \"all_files = glob.glob(os.path.join(path, \\\"average_driving_times_scenario*.csv\\\"))\\n\",\n",
    "    \"\\n\",\n",
    "    \"df_list = []\\n\",\n",
    "    \"\\n\",\n",
    "    \"for filename in all_files:\\n\",\n",
    "    \"    match = re.search(r'scenario(\\\\d+)', filename)\\n\",\n",
    "    \"    if match:\\n\",\n",
    "    \"        scenario_num = int(match.group(1))\\n\",\n",
    "    \"\\n\",\n",
    "    \"        df = pd.read_csv(filename)\\n\",\n",
    "    \"        df['Scenario'] = f'S{scenario_num}'\\n\",\n",
    "    \"        df['Scenario_Int'] = scenario_num\\n\",\n",
    "    \"        df_list.append(df)\\n\",\n",
    "    \"\\n\",\n",
    "    \"if df_list:\\n\",\n",
    "    \"    full_df = pd.concat(df_list, ignore_index=True).sort_values('Scenario_Int')\\n\",\n",
    "    \"\\n\",\n",
    "    \"#visual 1  -boxplot\\n\",\n",
    "    \"    plt.figure()\\n\",\n",
    "    \"    sns.boxplot(x='Scenario', y='Average Driving Time', data=full_df, palette='viridis')\\n\",\n",
    "    \"    plt.title('Comparison of Average Driving Times per Scenario', fontsize=16)\\n\",\n",
    "    \"    plt.ylabel('Driving Time (Minutes)', fontsize=13)\\n\",\n",
    "    \"    plt.xlabel('Scenario', fontsize=13)\\n\",\n",
    "    \"    plt.savefig('../img/boxplot_scenarios.png', dpi=300)\\n\",\n",
    "    \"    plt.show()\\n\",\n",
    "    \"\\n\"\n",
    "   ],\n",
