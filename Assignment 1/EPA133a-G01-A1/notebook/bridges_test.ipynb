    "#filter locations outside of Bangladesh\n",
    "outside_bounds = (\n",
    "    (df_bridges['lat'] < LAT_MIN) | (df_bridges['lat'] > LAT_MAX) |\n",
    "    (df_bridges['lon'] < LON_MIN) | (df_bridges['lon'] > LON_MAX)\n",
